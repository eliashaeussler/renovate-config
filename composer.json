{
	"name": "eliashaeussler/renovate-config",
	"description": "My personal configuration for Renovate",
	"license": "GPL-3.0-or-later",
	"type": "library",
	"authors": [
		{
			"name": "Elias Häußler",
			"email": "elias@haeussler.dev",
			"homepage": "https://haeussler.dev",
			"role": "Maintainer"
		}
	],
	"require-dev": {
		"armin/editorconfig-cli": "^2.0",
		"ergebnis/composer-normalize": "^2.29"
	},
	"config": {
		"allow-plugins": {
			"ergebnis/composer-normalize": true
		},
		"sort-packages": true
	},
	"scripts": {
		"check": [
			"@check:style"
		],
		"check:style": [
			"@check:style:composer",
			"@check:style:editorconfig"
		],
		"check:style:composer": "@fix:composer --dry-run",
		"check:style:editorconfig": "ec",
		"ci": [
			"@composer validate --strict",
			"@composer audit",
			"@check",
			"@validate-config"
		],
		"fix": [
			"@fix:composer",
			"@fix:editorconfig"
		],
		"fix:composer": "@composer normalize",
		"fix:editorconfig": "@check:style:editorconfig --fix",
		"validate-config": "docker compose run --rm validate"
	}
}
